stickiness_by_issuer_boa_ym <- dt %>%
  filter(!is.na(LU1_name)) %>%                       # Keep rows with LU1_name
  distinct(complete_cusip, .keep_all = TRUE) %>%     # One observation per bond
  group_by(issuer_cusip, boa, ym, LU1_name) %>%      # Group also by time period ym
  summarise(num_deals = n(), .groups = "drop") %>%   # Count deals per underwriter per issuer + boa + ym
  group_by(issuer_cusip, boa, ym) %>%                 # Regroup without underwriter to compute totals
  mutate(
    total_deals = sum(num_deals),                     # Total deals for issuer, boa, ym
    stickiness = max(num_deals) / total_deals         # Stickiness = share by top underwriter
  ) %>%
  slice_max(num_deals, with_ties = FALSE) %>%         # Keep only top underwriter per group
  ungroup()



# Compute average stickiness per ym and boa
stickiness_ts <- stickiness_by_issuer_boa_ym %>%
  group_by(ym, boa) %>%
  summarise(mean_stickiness = mean(stickiness, na.rm = TRUE),
            .groups = "drop")


# Plot the two time series of boa = 1 and boa = 0
ggplot(stickiness_ts, aes(x = ym, y = mean_stickiness, color = factor(boa), group = boa)) +
  geom_line(size = 1) +
  geom_point() +
  labs(
    title = "Average Lead Underwriter Stickiness Over Time",
    x = "Year-Quarter",
    y = "Mean Stickiness Ratio",
    color = "BOA Index"
  ) +
  scale_color_manual(values = c("0" = "red", "1" = "blue"),
                     labels = c("Non-BOA (0)", "BOA (1)")) +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))






