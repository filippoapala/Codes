### ------MEASURE OF STICKNESS, Number of deals with the issuer’s most-used underwriter / Total number of issues, this measure belongs to [0,1]----- ###

stickiness_by_issuer <- dt %>%
  filter(!is.na(LU1_name)) %>%   # Exclude rows where the lead underwriter is missing
  distinct(complete_cusip, .keep_all = TRUE) %>%   # Remove duplicates per bond
  group_by(issuer_cusip, LU1_name) %>%   # Group by issuer and lead underwriter, so every further operation is made at at issuer level
  summarise(num_deals = n(), .groups = "drop") %>%   # Count how many unique deals per pair
  group_by(issuer_cusip) %>%   # Now group just by issuer
  mutate(
    total_deals = sum(num_deals),  # Total deals per issuer
    stickiness = max(num_deals) / total_deals  # Stickiness = share of top underwriter
  ) %>%
  slice_max(num_deals, with_ties = FALSE) %>%  # Keep only the top underwriter
  ungroup()  # Remove grouping

# View result
print(stickiness_by_issuer)



### MEASURE OF STICKNESS DEPENDING ON THE INDEX ###
stickiness_by_issuer_boa <- dt %>%
  filter(!is.na(LU1_name)) %>%                          # Only keep rows with a lead underwriter
  distinct(complete_cusip, .keep_all = TRUE) %>%        # Keep one observation per bond
  group_by(issuer_cusip, boa, LU1_name) %>%             # Group by issuer, BOA flag, and underwriter
  summarise(num_deals = n(), .groups = "drop") %>%
  group_by(issuer_cusip, boa) %>%                       # Regroup by issuer and boa
  mutate(
    total_deals = sum(num_deals),                      # Total deals for each issuer in that BOA group
    stickiness = max(num_deals) / total_deals          # Stickiness = share of deals from top underwriter
  ) %>%
  slice_max(num_deals, with_ties = FALSE) %>%           # Keep only the top underwriter per issuer + BOA group
  ungroup()

# View result
head(stickiness_by_issuer_boa)


# Compute mean stickiness separately for boa = 0 and boa = 1
mean_stickiness_by_boa <- stickiness_by_issuer_boa %>%
  group_by(boa) %>%
  summarise(mean_stickiness = mean(stickiness, na.rm = TRUE))

# View result
print(mean_stickiness_by_boa)



